{
  "spec_version": "v1",
  "date": "2026-03-17",
  "units": {
    "length": "m",
    "screen_uv": "m"
  },
  "physical_context": {
    "fabrication": "Al substrate + NiP + SPDT + light polishing",
    "measurement": "PMD deflectometry, single camera + single screen",
    "clear_aperture": {
      "type": "circle",
      "diameter_m": 0.05
    }
  },
  "grid": {
    "H": 512,
    "W": 512,
    "radius_m": 0.025,
    "x0_m": -0.025,
    "y0_m": -0.025,
    "dx_m": 9.784735812133073e-05,
    "dy_m": 9.784735812133073e-05
  },
  "screen": {
    "width_m": 0.53,
    "height_m": 0.3,
    "width_px": 1920,
    "height_px": 1080,
    "pixel_pitch_m": 0.0002760416666666667
  },
  "extrinsics_v1_placeholder": {
    "T_WM": "Identity (world aligned with mirror)",
    "T_WC_translation_m": [
      0.0,
      0.0,
      0.2
    ],
    "T_WS_translation_m": [
      0.0,
      0.0,
      0.5
    ],
    "note": "v1 allows translation-only; rotations to be added later when real calibration is available."
  },
  "surface_families": {
    "A_baseline": {
      "design_model": "XY polynomial degree 6 (or low-order Zernike)",
      "target_pv_sag_m_range": [
        0.0003,
        0.0015
      ],
      "max_slope_limit": 0.18,
      "fixed_design_id": "A1",
      "note": "Calibration-friendly baseline freeform"
    },
    "B_challenge": {
      "design_model": "Toroid/saddle-like base + mild polynomial perturbation",
      "target_pv_sag_m_range": [
        0.0005,
        0.002
      ],
      "max_slope_limit": 0.25,
      "fixed_design_id": "B1",
      "note": "Challenge freeform with stronger curvature gradients"
    },
    "C_multiscale": {
      "design_model": "Same base as A + MSF ripple + defect (geometry)",
      "target_pv_sag_m_range": [
        0.0003,
        0.0015
      ],
      "max_slope_limit": 0.18,
      "fixed_design_id": "C1",
      "note": "Training-friendly multi-scale surface"
    }
  },
  "manufacturing_error_model": {
    "LF_lowfreq": {
      "enabled": true,
      "basis": "low-order polynomial or Zernike (few terms)",
      "rms_m_range": [
        5e-07,
        5e-06
      ],
      "terms_range": [
        3,
        8
      ]
    },
    "MSF_midfreq": {
      "enabled": true,
      "model": "sum of sinusoids (+ optional band-limited random field)",
      "sinusoids_K_range": [
        2,
        4
      ],
      "amplitude_m_range": [
        1e-07,
        1e-06
      ],
      "wavelength_m_range": [
        0.001,
        0.005
      ],
      "random_field_enabled": false,
      "random_field_rms_m_range": [
        5e-08,
        5e-07
      ],
      "random_field_band_m": [
        0.001,
        0.008
      ]
    }
  },
  "defect_model": {
    "geometry_defects": {
      "enabled": true,
      "types": {
        "gaussian_pit": {
          "prob": 0.5,
          "A_m_abs_range": [
            2e-07,
            5e-06
          ],
          "sigma_m_range": [
            0.00015,
            0.0008
          ],
          "center_radius_m_max": 0.02
        },
        "scratch": {
          "prob": 0.5,
          "A_m_abs_range": [
            5e-08,
            1e-06
          ],
          "width_m_range": [
            3e-05,
            0.00015
          ],
          "length_m_range": [
            0.005,
            0.02
          ],
          "center_radius_m_max": 0.018
        }
      }
    },
    "non_geometry_anomalies": {
      "enabled": true,
      "conf_drop": {
        "prob": 0.4,
        "num_blobs_range": [
          1,
          4
        ],
        "blob_sigma_m_range": [
          0.0004,
          0.002
        ],
        "min_conf_scale_range": [
          0.0,
          0.6
        ]
      },
      "uv_noise_boost": {
        "prob": 0.4,
        "num_blobs_range": [
          1,
          4
        ],
        "blob_sigma_m_range": [
          0.0004,
          0.002
        ],
        "noise_scale_multiplier_range": [
          2.0,
          8.0
        ]
      }
    }
  },
  "observation_noise_model": {
    "uv_gaussian_noise": {
      "enabled": true,
      "sigma_u_m_range": [
        5e-05,
        0.0003
      ],
      "sigma_v_m_range": [
        5e-05,
        0.0003
      ]
    },
    "uv_lowfreq_distortion": {
      "enabled": true,
      "poly_degree": 2,
      "coef_scale_m_range": [
        0.0,
        0.0005
      ]
    },
    "conf_masking": {
      "enabled": true,
      "edge_falloff": {
        "enabled": true,
        "power_range": [
          1.5,
          3.5
        ]
      },
      "high_slope_penalty": {
        "enabled": true,
        "slope0_range": [
          0.12,
          0.2
        ]
      },
      "random_drop": {
        "enabled": true,
        "drop_prob_range": [
          0.0,
          0.08
        ]
      }
    }
  },
  "cmm_model": {
    "Ncmm_default": 50,
    "Ncmm_scan": [
      0,
      10,
      30,
      50,
      100
    ],
    "z_noise_m_range": [
      5e-08,
      5e-07
    ],
    "xy_noise_m_range": [
      0.0,
      0.0
    ],
    "sampling_strategy": "uniform within aperture (v1); later add curvature-weighted option"
  },
  "anti_leakage_rules": {
    "must_not_save": [
      "p_gt",
      "q_gt",
      "n_gt",
      "forward_intermediates",
      "defect_mask (inside sample folder)",
      "any direct 'answer' fields usable as supervision"
    ],
    "surface_gt_usage": "evaluation_only",
    "design_surface_usage": "allowed_as_prior_with_ablation"
  },
  "reproducibility": {
    "global_seed": 0,
    "per_sample_seed_rule": "seed = global_seed + sample_index",
    "required_outputs": [
      "dataset_manifest_v1.json",
      "per-sample calib.json includes summary only"
    ]
  },
  "output_files": {
    "required": [
      "surface_gt.npy",
      "deflect_obs.npy",
      "cmm_points.npy",
      "calib.json"
    ],
    "optional": [
      "design_surface.npy"
    ]
  }
}